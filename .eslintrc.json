{
  "root": true,
  "env": {
    "es2022": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["off"],
    "semi": ["error", "always"],
    "quotes": ["error", "single"]
  },
  "overrides": [
    {
      "files": ["backend/**/*.js"],
      "env": { "node": true }
    },
    {
      "files": ["frontend/**/*.js"],
      "env": { "browser": true },
      "globals": {
        "tf": "readonly",
        "tfvis": "readonly"
      }
    }
  ]
}